# ── Database ────────────────────────────────────────────────────────────────
# SQLite for local development (file path relative to project root)
DATABASE_URL="file:./dev.db"

# For production (PostgreSQL), swap to:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/grantmatch?schema=public"

# ── Anthropic ────────────────────────────────────────────────────────────────
# Required for the "Find grants" search feature.
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# Optional: override the model used for grant search (defaults to claude-opus-4-6)
# ANTHROPIC_MODEL="claude-sonnet-4-6"
